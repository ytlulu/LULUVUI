-- Label teks biasa
local function _mkLabel(parent, text, yOff, h, size, bold, color, theme)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, -16, 0, h or 20)
    l.Position = UDim2.new(0, 8, 0, yOff)
    l.BackgroundTransparency = 1
    l.Text = text
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextSize = size or 12
    l.TextColor3 = color or theme.textWhite
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = parent
    return l, h or 20
end

-- Garis divider
local function _mkDivider(parent, yOff, theme)
    local d = Instance.new("Frame")
    d.Size = UDim2.new(1, -16, 0, 1)
    d.Position = UDim2.new(0, 8, 0, yOff)
    d.BackgroundColor3 = theme.divider
    d.BorderSizePixel = 0
    d.Parent = parent
    return d, 1
end

-- Tombol penuh
local function _mkBtn(parent, text, yOff, h, col, theme)
    col = col or theme.accent
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -16, 0, h or 30)
    b.Position = UDim2.new(0, 8, 0, yOff)
    b.BackgroundColor3 = col
    b.Text = text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 12
    b.TextColor3 = theme.textWhite
    b.BorderSizePixel = 0
    b.Parent = parent
    mkCorner(b, 8)
    makeHover(b, col, lighten(col))
    return b, h or 30
end

-- Dua tombol setengah lebar berdampingan
-- colA default hijau (Start), colB default merah (Stop)
local function _mkHalfBtns(parent, textA, textB, yOff, h, colA, colB, theme)
    h = h or 30
    colA = colA or Color3.fromRGB(40, 180, 80)
    colB = colB or Color3.fromRGB(200, 50, 50)

    local bA = Instance.new("TextButton")
    bA.Size = UDim2.new(0.5, -12, 0, h)
    bA.Position = UDim2.new(0, 8, 0, yOff)
    bA.BackgroundColor3 = colA
    bA.Text = textA
    bA.Font = Enum.Font.GothamBold
    bA.TextSize = 11
    bA.TextColor3 = theme.textWhite
    bA.BorderSizePixel = 0
    bA.Parent = parent
    mkCorner(bA, 8)
    makeHover(bA, colA, lighten(colA))

    local bB = Instance.new("TextButton")
    bB.Size = UDim2.new(0.5, -12, 0, h)
    bB.Position = UDim2.new(0.5, 4, 0, yOff)
    bB.BackgroundColor3 = colB
    bB.Text = textB
    bB.Font = Enum.Font.GothamBold
    bB.TextSize = 11
    bB.TextColor3 = theme.textWhite
    bB.BorderSizePixel = 0
    bB.Parent = parent
    mkCorner(bB, 8)
    makeHover(bB, colB, lighten(colB))

    return bA, bB, h
end

-- Toggle switch
local function _mkToggle(parent, label, yOff, default, callback, theme)
    local state = {default}
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, 32)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = theme.contentBg
    bg.BorderSizePixel = 0
    bg.Parent = parent
    mkCorner(bg, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -60, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextColor3 = theme.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = bg

    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 38, 0, 20)
    track.Position = UDim2.new(1, -46, 0.5, -10)
    track.BackgroundColor3 = default and theme.toggleOn or theme.toggleOff
    track.BorderSizePixel = 0
    track.Parent = bg
    mkCorner(track, 10)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = default and UDim2.new(0, 20, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = theme.textWhite
    knob.BorderSizePixel = 0
    knob.Parent = track
    mkCorner(knob, 8)

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""
    btn.Parent = bg

    btn.MouseButton1Click:Connect(function()
        state[1] = not state[1]
        local on = state[1]
        TweenService:Create(track, TweenInfo.new(0.2), {
            BackgroundColor3 = on and theme.toggleOn or theme.toggleOff
        }):Play()
        TweenService:Create(knob, TweenInfo.new(0.2), {
            Position = on and UDim2.new(0, 20, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
        }):Play()
        if callback then callback(on) end
    end)

    return bg, 32
end

-- Dropdown
local function _mkDropdown(parent, mainFrame, label, options, default, yOff, callback, theme)
    local open = {false}

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, 32)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = theme.contentBg
    bg.BorderSizePixel = 0
    bg.ClipsDescendants = false
    bg.Parent = parent
    mkCorner(bg, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.55, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextColor3 = theme.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = bg

    local valBtn = Instance.new("TextButton")
    valBtn.Size = UDim2.new(0, 100, 0, 24)
    valBtn.Position = UDim2.new(1, -108, 0.5, -12)
    valBtn.BackgroundColor3 = theme.accent
    valBtn.Text = default .. " ▾"
    valBtn.Font = Enum.Font.GothamBold
    valBtn.TextSize = 11
    valBtn.TextColor3 = theme.textWhite
    valBtn.BorderSizePixel = 0
    valBtn.Parent = bg
    mkCorner(valBtn, 6)

    local dropMenu = Instance.new("Frame")
    dropMenu.Size = UDim2.new(0, 100, 0, #options * 28)
    dropMenu.BackgroundColor3 = theme.textWhite
    dropMenu.BorderSizePixel = 0
    dropMenu.Visible = false
    dropMenu.ZIndex = 200
    mkCorner(dropMenu, 8)

    local ds = Instance.new("Frame")
    ds.Size = UDim2.new(1, 8, 1, 8)
    ds.Position = UDim2.new(0, -4, 0, -4)
    ds.BackgroundColor3 = theme.accent
    ds.BackgroundTransparency = 0.85
    ds.BorderSizePixel = 0
    ds.ZIndex = 199
    ds.Parent = dropMenu
    mkCorner(ds, 10)

    for i, opt in ipairs(options) do
        local ob = Instance.new("TextButton")
        ob.Size = UDim2.new(1, 0, 0, 28)
        ob.Position = UDim2.new(0, 0, 0, (i - 1) * 28)
        ob.BackgroundTransparency = 1
        ob.Text = opt
        ob.Font = Enum.Font.Gotham
        ob.TextSize = 12
        ob.TextColor3 = theme.text
        ob.ZIndex = 201
        ob.Parent = dropMenu
        makeHover(ob, theme.textWhite, Color3.fromRGB(235, 240, 255))
        ob.BackgroundTransparency = 1
        ob.MouseButton1Click:Connect(function()
            valBtn.Text = opt .. " ▾"
            dropMenu.Visible = false
            dropMenu.Parent = nil
            open[1] = false
            if callback then callback(opt) end
        end)
    end

    valBtn.MouseButton1Click:Connect(function()
        open[1] = not open[1]
        if open[1] then
            local absPos   = valBtn.AbsolutePosition
            local framePos = mainFrame.AbsolutePosition
            local menuW    = valBtn.AbsoluteSize.X  -- ikut lebar tombol
            dropMenu.Size  = UDim2.new(0, menuW, 0, #options * 28)
            dropMenu.Position = UDim2.new(0, absPos.X - framePos.X, 0,
                absPos.Y - framePos.Y + valBtn.AbsoluteSize.Y + 4)
            dropMenu.Parent = mainFrame
            dropMenu.Visible = true
        else
            dropMenu.Visible = false
            dropMenu.Parent = nil
        end
    end)

    return bg, 32
end

-- Multi-select Dropdown
local function _mkMultiDropdown(parent, mainFrame, label, options, defaults, yOff, callback, theme)
    local open    = {false}
    local selected = {}  -- set: selected[opt] = true

    -- init defaults
    if defaults then
        for _, v in ipairs(defaults) do selected[v] = true end
    end

    local function countSelected()
        local n = 0
        for _ in pairs(selected) do n = n + 1 end
        return n
    end

    local function getLabel()
        local n = countSelected()
        if n == 0 then return "— none — ▾" end
        if n == 1 then
            for k in pairs(selected) do return k .. " ▾" end
        end
        return n .. " selected ▾"
    end

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, 32)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = theme.contentBg
    bg.BorderSizePixel = 0
    bg.ClipsDescendants = false
    bg.Parent = parent
    mkCorner(bg, 8)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.5, 0, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextColor3 = theme.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = bg

    local valBtn = Instance.new("TextButton")
    valBtn.Size = UDim2.new(0, 110, 0, 24)
    valBtn.Position = UDim2.new(1, -118, 0.5, -12)
    valBtn.BackgroundColor3 = theme.accent
    valBtn.Text = getLabel()
    valBtn.Font = Enum.Font.GothamBold
    valBtn.TextSize = 10
    valBtn.TextColor3 = theme.textWhite
    valBtn.BorderSizePixel = 0
    valBtn.TextTruncate = Enum.TextTruncate.AtEnd
    valBtn.Parent = bg
    mkCorner(valBtn, 6)

    local itemH   = 30
    local maxShow = math.min(#options, 6)
    local menuH   = maxShow * itemH + 4

    local dropMenu = Instance.new("Frame")
    dropMenu.Size = UDim2.new(0, 150, 0, menuH)
    dropMenu.BackgroundColor3 = theme.textWhite
    dropMenu.BorderSizePixel = 0
    dropMenu.Visible = false
    dropMenu.ZIndex = 200
    dropMenu.ClipsDescendants = true
    mkCorner(dropMenu, 8)

    -- shadow/glow
    local ds = Instance.new("Frame")
    ds.Size = UDim2.new(1, 8, 1, 8)
    ds.Position = UDim2.new(0, -4, 0, -4)
    ds.BackgroundColor3 = theme.accent
    ds.BackgroundTransparency = 0.85
    ds.BorderSizePixel = 0
    ds.ZIndex = 199
    ds.Parent = dropMenu
    mkCorner(ds, 10)

    -- ScrollingFrame supaya kalau opsi banyak bisa scroll
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * itemH)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = theme.accent
    scroll.ZIndex = 201
    scroll.Parent = dropMenu

    local itemRows = {}  -- simpan tiap row buat refresh warna

    local function refreshRow(opt, row, check)
        local on = selected[opt] == true
        row.BackgroundColor3 = on and Color3.fromRGB(235, 245, 255) or theme.textWhite
        check.Text = on and "✓" or ""
        check.TextColor3 = theme.accent
    end

    for i, opt in ipairs(options) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1, 0, 0, itemH)
        row.Position = UDim2.new(0, 0, 0, (i - 1) * itemH)
        row.BackgroundColor3 = selected[opt] and Color3.fromRGB(235, 245, 255) or theme.textWhite
        row.BorderSizePixel = 0
        row.Text = ""
        row.ZIndex = 202
        row.Parent = scroll
        mkCorner(row, 0)

        -- Checkmark box
        local check = Instance.new("TextLabel")
        check.Size = UDim2.new(0, 20, 0, 20)
        check.Position = UDim2.new(0, 6, 0.5, -10)
        check.BackgroundColor3 = theme.contentBg
        check.BorderSizePixel = 0
        check.Text = selected[opt] and "✓" or ""
        check.Font = Enum.Font.GothamBold
        check.TextSize = 12
        check.TextColor3 = theme.accent
        check.TextXAlignment = Enum.TextXAlignment.Center
        check.ZIndex = 203
        check.Parent = row
        mkCorner(check, 4)

        -- Nama opsi
        local optLbl = Instance.new("TextLabel")
        optLbl.Size = UDim2.new(1, -34, 1, 0)
        optLbl.Position = UDim2.new(0, 32, 0, 0)
        optLbl.BackgroundTransparency = 1
        optLbl.Text = opt
        optLbl.Font = Enum.Font.Gotham
        optLbl.TextSize = 12
        optLbl.TextColor3 = theme.text
        optLbl.TextXAlignment = Enum.TextXAlignment.Left
        optLbl.ZIndex = 203
        optLbl.Parent = row

        table.insert(itemRows, {opt = opt, row = row, check = check})

        row.MouseButton1Click:Connect(function()
            -- Toggle
            if selected[opt] then
                selected[opt] = nil
            else
                selected[opt] = true
            end
            -- Refresh semua row (biar konsisten)
            for _, r in ipairs(itemRows) do
                refreshRow(r.opt, r.row, r.check)
            end
            -- Update label tombol
            valBtn.Text = getLabel()
            -- Kirim tabel hasil ke callback
            if callback then
                local result = {}
                for k in pairs(selected) do table.insert(result, k) end
                callback(result)
            end
        end)
    end

    -- Open / close menu
    local function closeMenu()
        dropMenu.Visible = false
        dropMenu.Parent = nil
        open[1] = false
    end

    valBtn.MouseButton1Click:Connect(function()
        open[1] = not open[1]
        if open[1] then
            local absPos   = valBtn.AbsolutePosition
            local framePos = mainFrame.AbsolutePosition
            local menuW    = math.max(valBtn.AbsoluteSize.X, 150)  -- min 150
            dropMenu.Size  = UDim2.new(0, menuW, 0, menuH)
            dropMenu.Position = UDim2.new(0, absPos.X - framePos.X, 0,
                absPos.Y - framePos.Y + valBtn.AbsoluteSize.Y + 4)
            dropMenu.Parent = mainFrame
            dropMenu.Visible = true
        else
            closeMenu()
        end
    end)

    return bg, 32
end

