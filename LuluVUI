-- ============================================================
-- TOAST NOTIFICATION
-- ============================================================
function Window:Toast(msg, color)
    local theme = self._theme
    color = color or theme.toast
    table.insert(self._toastQueue, {msg = msg, color = color})
    if self._toastRunning then return end
    self._toastRunning = true
    task.spawn(function()
        while #self._toastQueue > 0 do
            local item = table.remove(self._toastQueue, 1)

            local toast = Instance.new("Frame")
            toast.Size = UDim2.new(0, 220, 0, 36)
            toast.Position = UDim2.new(1, -10, 1, 10)
            toast.AnchorPoint = Vector2.new(1, 1)
            toast.BackgroundColor3 = item.color
            toast.BackgroundTransparency = 0.1
            toast.BorderSizePixel = 0
            toast.ZIndex = 999
            toast.ClipsDescendants = true
            toast.Parent = self.screenGui
            mkCorner(toast, 8)

            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, -16, 1, 0)
            lbl.Position = UDim2.new(0, 8, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = item.msg
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 11
            lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
            lbl.TextXAlignment = Enum.TextXAlignment.Left
            lbl.TextTruncate = Enum.TextTruncate.AtEnd
            lbl.ZIndex = 1000
            lbl.Parent = toast

            TweenService:Create(toast,
                TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                {Position = UDim2.new(1, -10, 1, -10)}
            ):Play()
            task.wait(2.8)
            TweenService:Create(toast,
                TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                {Position = UDim2.new(1, -10, 1, 10)}
            ):Play()
            task.wait(0.22)
            pcall(function() toast:Destroy() end)
            task.wait(0.1)
        end
        self._toastRunning = false
    end)
end

-- ============================================================
-- INFO PANEL (overlay kanan atas, optional)
-- ============================================================
function Window:InfoPanel(cfg)
    cfg = cfg or {}
    local theme = self._theme

    local panel = Instance.new("Frame")
    panel.Size = UDim2.new(0, cfg.width or 180, 0, cfg.height or 100)
    panel.Position = cfg.position or UDim2.new(1, -190, 0, 10)
    panel.BackgroundColor3 = cfg.bg or Color3.fromRGB(15, 20, 35)
    panel.BackgroundTransparency = 0.2
    panel.BorderSizePixel = 0
    panel.Visible = cfg.visible ~= false
    panel.Parent = self.screenGui
    mkCorner(panel, 10)
    self:_setupDrag(panel, panel)

    local api = {frame = panel, _y = 4}

    function api:Line(text)
        local l = Instance.new("TextLabel")
        l.Size = UDim2.new(1, -10, 0, 16)
        l.Position = UDim2.new(0, 6, 0, self._y)
        l.BackgroundTransparency = 1
        l.Text = text
        l.Font = Enum.Font.GothamBold
        l.TextSize = 10
        l.TextColor3 = Color3.fromRGB(200, 220, 255)
        l.TextXAlignment = Enum.TextXAlignment.Left
        l.TextTruncate = Enum.TextTruncate.AtEnd
        l.Parent = panel
        self._y = self._y + 18
        return l  -- caller bisa update .Text langsung
    end

    function api:Show() panel.Visible = true  end
    function api:Hide() panel.Visible = false end
    function api:Toggle() panel.Visible = not panel.Visible end

    return api
end

-- ============================================================
-- SETTERS
-- ============================================================
function Window:SetTitle(text)
    self.titleLabel.Text = text
end

-- Shortcut confirm dialog langsung dari window
-- win:Confirm("Judul", "Pesan?", function() ... end)
function Window:Confirm(title, message, onConfirm, onCancel)
    _showConfirm(self.mainFrame, title, message, onConfirm, onCancel, self._theme)
end

function Window:Destroy()
    self.screenGui:Destroy()
end

