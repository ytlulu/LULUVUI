-- accordionStates sekarang optional — kalau nil, library auto-manage internal
-- closers: tabel shared dari Window._openMenuClosers — dipakai Dropdown untuk register closeMenu
function Section.new(container, mainFrame, theme, accordionStates, closers)
    return setmetatable({
        _c  = container,
        _mf = mainFrame,
        _t  = theme,
        _as = accordionStates or {},
        _cl = closers or {},   -- shared registry: {fn, fn, ...}
        _y  = 0,
    }, Section)
end

local DEFAULT_GAP = 6

function Section:Label(text, opts)
    opts = opts or {}
    local h = opts.height or 20
    _mkLabel(self._c, text, self._y, h, opts.size, opts.bold, opts.color, self._t)
    self._y = self._y + h + (opts.gap or 4)
end

