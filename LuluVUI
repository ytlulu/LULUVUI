-- Toggle switch
-- opts.subtext  → string, kalau ada maka tinggi 48px dan ada subtext di bawah label
-- opts.disabled → bool, kalau true: greyed out, tidak bisa diklik
local function _mkToggle(parent, label, yOff, default, callback, theme, opts)
    opts = opts or {}
    local subtext  = opts.subtext
    local disabled = opts.disabled == true
    local totalH   = subtext and 48 or 28

    local state = {default}
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, totalH)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = disabled and theme.divider or theme.contentBg
    bg.BorderSizePixel = 0
    bg.Parent = parent
    mkCorner(bg, 8)

    local textColor = disabled and theme.accordionTxt or theme.text

    if subtext then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -60, 0, 18)
        lbl.Position = UDim2.new(0, 10, 0, 8)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 13
        lbl.TextColor3 = textColor
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = bg

        local sub = Instance.new("TextLabel")
        sub.Size = UDim2.new(1, -60, 0, 14)
        sub.Position = UDim2.new(0, 10, 0, 27)
        sub.BackgroundTransparency = 1
        sub.Text = subtext
        sub.Font = Enum.Font.Gotham
        sub.TextSize = 10
        sub.TextColor3 = theme.accordionTxt
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.Parent = bg
    else
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -60, 1, 0)
        lbl.Position = UDim2.new(0, 10, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = label
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        lbl.TextColor3 = textColor
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = bg
    end

    -- Track & knob — kalau disabled, warna pudar
    local trackColor = disabled and theme.divider
        or (default and theme.toggleOn or theme.toggleOff)
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0, 38, 0, 20)
    track.Position = UDim2.new(1, -46, 0.5, -10)
    track.BackgroundColor3 = trackColor
    track.BorderSizePixel = 0
    track.Parent = bg
    mkCorner(track, 10)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = default and UDim2.new(0, 20, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    knob.BackgroundColor3 = disabled and theme.accordionTxt or theme.textWhite
    knob.BorderSizePixel = 0
    knob.Parent = track
    mkCorner(knob, 8)

    -- Transparent overlay untuk clickable area — skip kalau disabled
    if not disabled then
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text = ""
        btn.Parent = bg

        btn.MouseButton1Click:Connect(function()
            state[1] = not state[1]
            local on = state[1]
            TweenService:Create(track, TweenInfo.new(0.2), {
                BackgroundColor3 = on and theme.toggleOn or theme.toggleOff
            }):Play()
            TweenService:Create(knob, TweenInfo.new(0.2), {
                Position = on and UDim2.new(0, 20, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
            }):Play()
            if callback then callback(on) end
        end)
    end

    return bg, totalH
end

-- Dropdown
-- Return: bg, 32, proxy
-- proxy:SetOptions(newOpts, keepValue?)  → update opsi tanpa rebuild widget
-- proxy:SetValue(text)                  → set label tombol secara manual
local function _mkDropdown(parent, mainFrame, label, options, default, yOff, callback, theme, closers)
    local open        = {false}
    local currentOpts = options

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, 32)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = theme.contentBg
    bg.BorderSizePixel = 0
    bg.ClipsDescendants = false
    bg.Parent = parent
    mkCorner(bg, 8)

    -- Label kiri: fix 40% lebar
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.4, -14, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextColor3 = theme.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTruncate = Enum.TextTruncate.AtEnd
    lbl.Parent = bg

    -- Tombol kanan: stretch ngikut sisa lebar row
    local valBtn = Instance.new("TextButton")
    valBtn.Size = UDim2.new(0.6, -14, 0, 24)
    valBtn.Position = UDim2.new(0.4, 6, 0.5, -12)
    valBtn.BackgroundColor3 = theme.accent
    valBtn.Text = default .. " +"
    valBtn.Font = Enum.Font.GothamBold
    valBtn.TextSize = 11
    valBtn.TextColor3 = theme.textWhite
    valBtn.BorderSizePixel = 0
    valBtn.TextTruncate = Enum.TextTruncate.AtEnd
    valBtn.Parent = bg
    mkCorner(valBtn, 6)

    local ITEM_H   = 28
    local MAX_SHOW = 6   -- maksimal item visible sebelum scroll

    -- Wrapper frame (background + shadow + clip)
    local dropMenu = Instance.new("Frame")
    dropMenu.BackgroundColor3 = theme.textWhite
    dropMenu.BorderSizePixel  = 0
    dropMenu.Visible          = false
    dropMenu.ZIndex           = 200
    dropMenu.ClipsDescendants = true
    mkCorner(dropMenu, 8)

    -- Shadow / glow
    local ds = Instance.new("Frame")
    ds.Size                  = UDim2.new(1, 8, 1, 8)
    ds.Position              = UDim2.new(0, -4, 0, -4)
    ds.BackgroundColor3      = theme.accent
    ds.BackgroundTransparency = 0.85
    ds.BorderSizePixel        = 0
    ds.ZIndex                 = 199
    ds.Parent                 = dropMenu
    mkCorner(ds, 10)

    -- ScrollingFrame di dalam dropMenu
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size                  = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel        = 0
    scroll.ScrollBarThickness     = 4
    scroll.ScrollBarImageColor3   = theme.accent
    scroll.CanvasSize             = UDim2.new(0, 0, 0, 0)   -- di-set ulang tiap rebuild
    scroll.ZIndex                 = 201
    scroll.Parent                 = dropMenu

    --  closeMenu 
    local function closeMenu()
        if open[1] then
            dropMenu.Visible = false
            dropMenu.Parent  = nil
            open[1]          = false
            -- restore open indicator
            local cur = valBtn.Text:gsub("%s*%+$", ""):gsub("%s*%-$", "")
            valBtn.Text = cur .. " +"
        end
    end

    if closers then table.insert(closers, closeMenu) end

    --  rebuildMenu 
    local function rebuildMenu(opts)
        -- bersihkan item lama
        for _, c in ipairs(scroll:GetChildren()) do c:Destroy() end

        scroll.CanvasSize = UDim2.new(0, 0, 0, #opts * ITEM_H)

        for i, opt in ipairs(opts) do
            local ob = Instance.new("TextButton")
            ob.Size                = UDim2.new(1, 0, 0, ITEM_H)
            ob.Position            = UDim2.new(0, 0, 0, (i - 1) * ITEM_H)
            ob.BackgroundTransparency = 1
            ob.Text                = opt
            ob.Font                = Enum.Font.Gotham
            ob.TextSize            = 12
            ob.TextColor3          = theme.text
            ob.ZIndex              = 202
            ob.Parent              = scroll
            makeHover(ob, theme.textWhite, Color3.fromRGB(235, 240, 255))
            ob.BackgroundTransparency = 1
            ob.MouseButton1Click:Connect(function()
                closeMenu()                  -- nutup dulu (restore "+ "), lalu
                valBtn.Text = opt .. " +"    -- overwrite dengan pilihan user
                if callback then callback(opt) end
            end)
        end
    end

    rebuildMenu(currentOpts)

    -- open/close menu
    local function openMenu()
        local visibleItems = math.min(#currentOpts, MAX_SHOW)
        local menuH        = visibleItems * ITEM_H
        local absPos       = valBtn.AbsolutePosition
        local framePos     = mainFrame.AbsolutePosition
        local menuW        = valBtn.AbsoluteSize.X
        dropMenu.Size      = UDim2.new(0, menuW, 0, menuH)
        dropMenu.Position  = UDim2.new(
            0, absPos.X - framePos.X,
            0, absPos.Y - framePos.Y + valBtn.AbsoluteSize.Y + 4
        )
        scroll.CanvasSize  = UDim2.new(0, 0, 0, #currentOpts * ITEM_H)
        dropMenu.Parent    = mainFrame
        dropMenu.Visible   = true
        open[1]            = true
        local cur = valBtn.Text:gsub("%s*%+$", ""):gsub("%s*%-$", "")
        valBtn.Text = cur .. " -"
    end

    valBtn.MouseButton1Click:Connect(function()
        if open[1] then closeMenu() else openMenu() end
    end)

    -- click outside: tutup saat klik di luar dropMenu & valBtn
    UserInputService.InputBegan:Connect(function(input)
        if not open[1] then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1
        and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local pos = input.Position
        local function isInside(gui)
            if not gui or not gui.Visible then return false end
            local ap = gui.AbsolutePosition
            local as = gui.AbsoluteSize
            return pos.X >= ap.X and pos.X <= ap.X + as.X
               and pos.Y >= ap.Y and pos.Y <= ap.Y + as.Y
        end
        if not isInside(dropMenu) and not isInside(valBtn) then
            closeMenu()
        end
    end)

    --  Proxy API 
    local proxy = {}

    function proxy:SetOptions(newOpts, keepValue)
        closeMenu()
        currentOpts = newOpts
        rebuildMenu(newOpts)
        if not keepValue then
            valBtn.Text = (newOpts[1] or "---") .. " +"
        end
    end

    function proxy:SetValue(text)
        valBtn.Text = text .. " +"
    end

    return bg, 32, proxy
end

-- Multi-select Dropdown
local function _mkMultiDropdown(parent, mainFrame, label, options, defaults, yOff, callback, theme)
    local open    = {false}
    local selected = {}  -- set: selected[opt] = true

    -- init defaults
    if defaults then
        for _, v in ipairs(defaults) do selected[v] = true end
    end

    local function countSelected()
        local n = 0
        for _ in pairs(selected) do n = n + 1 end
        return n
    end

    local function getLabel()
        local n = countSelected()
        if n == 0 then return "— none — " end
        if n == 1 then
            for k in pairs(selected) do return k .. " " end
        end
        return n .. " selected "
    end

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, -16, 0, 32)
    bg.Position = UDim2.new(0, 8, 0, yOff)
    bg.BackgroundColor3 = theme.contentBg
    bg.BorderSizePixel = 0
    bg.ClipsDescendants = false
    bg.Parent = parent
    mkCorner(bg, 8)

    -- Label kiri: fix 40% lebar
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.4, -14, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 12
    lbl.TextColor3 = theme.text
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTruncate = Enum.TextTruncate.AtEnd
    lbl.Parent = bg

    -- Tombol kanan: stretch ngikut sisa lebar row
    local valBtn = Instance.new("TextButton")
    valBtn.Size = UDim2.new(0.6, -14, 0, 24)
    valBtn.Position = UDim2.new(0.4, 6, 0.5, -12)
    valBtn.BackgroundColor3 = theme.accent
    valBtn.Text = getLabel()
    valBtn.Font = Enum.Font.GothamBold
    valBtn.TextSize = 11
    valBtn.TextColor3 = theme.textWhite
    valBtn.BorderSizePixel = 0
    valBtn.TextTruncate = Enum.TextTruncate.AtEnd
    valBtn.Parent = bg
    mkCorner(valBtn, 6)

    local itemH   = 30
    local maxShow = math.min(#options, 6)
    local menuH   = maxShow * itemH + 4

    local dropMenu = Instance.new("Frame")
    dropMenu.Size = UDim2.new(0, 150, 0, menuH)
    dropMenu.BackgroundColor3 = theme.textWhite
    dropMenu.BorderSizePixel = 0
    dropMenu.Visible = false
    dropMenu.ZIndex = 200
    dropMenu.ClipsDescendants = true
    mkCorner(dropMenu, 8)

    -- shadow/glow
    local ds = Instance.new("Frame")
    ds.Size = UDim2.new(1, 8, 1, 8)
    ds.Position = UDim2.new(0, -4, 0, -4)
    ds.BackgroundColor3 = theme.accent
    ds.BackgroundTransparency = 0.85
    ds.BorderSizePixel = 0
    ds.ZIndex = 199
    ds.Parent = dropMenu
    mkCorner(ds, 10)

    -- ScrollingFrame supaya kalau opsi banyak bisa scroll
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.CanvasSize = UDim2.new(0, 0, 0, #options * itemH)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = theme.accent
    scroll.ZIndex = 201
    scroll.Parent = dropMenu

    local itemRows = {}  -- simpan tiap row buat refresh warna

    local function refreshRow(opt, row, check)
        local on = selected[opt] == true
        row.BackgroundColor3 = on and Color3.fromRGB(235, 245, 255) or theme.textWhite
        check.Text = on and "" or ""
        check.TextColor3 = theme.accent
    end

    for i, opt in ipairs(options) do
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1, 0, 0, itemH)
        row.Position = UDim2.new(0, 0, 0, (i - 1) * itemH)
        row.BackgroundColor3 = selected[opt] and Color3.fromRGB(235, 245, 255) or theme.textWhite
        row.BorderSizePixel = 0
        row.Text = ""
        row.ZIndex = 202
        row.Parent = scroll
        mkCorner(row, 0)

        -- Checkmark box
        local check = Instance.new("TextLabel")
        check.Size = UDim2.new(0, 20, 0, 20)
        check.Position = UDim2.new(0, 6, 0.5, -10)
        check.BackgroundColor3 = theme.contentBg
        check.BorderSizePixel = 0
        check.Text = selected[opt] and "" or ""
        check.Font = Enum.Font.GothamBold
        check.TextSize = 12
        check.TextColor3 = theme.accent
        check.TextXAlignment = Enum.TextXAlignment.Center
        check.ZIndex = 203
        check.Parent = row
        mkCorner(check, 4)

        -- Nama opsi
        local optLbl = Instance.new("TextLabel")
        optLbl.Size = UDim2.new(1, -34, 1, 0)
        optLbl.Position = UDim2.new(0, 32, 0, 0)
        optLbl.BackgroundTransparency = 1
        optLbl.Text = opt
        optLbl.Font = Enum.Font.Gotham
        optLbl.TextSize = 12
        optLbl.TextColor3 = theme.text
        optLbl.TextXAlignment = Enum.TextXAlignment.Left
        optLbl.ZIndex = 203
        optLbl.Parent = row

        table.insert(itemRows, {opt = opt, row = row, check = check})

        row.MouseButton1Click:Connect(function()
            -- Toggle
            if selected[opt] then
                selected[opt] = nil
            else
                selected[opt] = true
            end
            -- Refresh semua row (biar konsisten)
            for _, r in ipairs(itemRows) do
                refreshRow(r.opt, r.row, r.check)
            end
            -- Update label tombol
            valBtn.Text = getLabel()
            -- Kirim tabel hasil ke callback
            if callback then
                local result = {}
                for k in pairs(selected) do table.insert(result, k) end
                callback(result)
            end
        end)
    end

    -- Open / close menu
    local function closeMenu()
        dropMenu.Visible = false
        dropMenu.Parent = nil
        open[1] = false
    end

    valBtn.MouseButton1Click:Connect(function()
        open[1] = not open[1]
        if open[1] then
            local absPos   = valBtn.AbsolutePosition
            local framePos = mainFrame.AbsolutePosition
            local menuW    = math.max(valBtn.AbsoluteSize.X, 150)  -- min 150
            dropMenu.Size  = UDim2.new(0, menuW, 0, menuH)
            dropMenu.Position = UDim2.new(0, absPos.X - framePos.X, 0,
                absPos.Y - framePos.Y + valBtn.AbsoluteSize.Y + 4)
            dropMenu.Parent = mainFrame
            dropMenu.Visible = true
        else
            closeMenu()
        end
    end)

    return bg, 32
end

