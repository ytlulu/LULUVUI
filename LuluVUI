-- Accordion dalam section → innerH OTOMATIS dihitung dari isi builderFn
-- Signature baru: Accordion(title, stateKey, builderFn, opts)
-- innerH tidak perlu diisi manual lagi
function Section:Accordion(title, stateKey, builderFn, opts)
    opts = opts or {}
    local theme         = self._t
    local accordionStates = self._as
    local open          = {accordionStates[stateKey] == true}
    local yOff          = self._y
    local parent        = self._c

    -- ── Header ───────────────────────────────────────────────
    local hdr = Instance.new("TextButton")
    hdr.Size = UDim2.new(1, -16, 0, 26)
    hdr.Position = UDim2.new(0, 8, 0, yOff)
    hdr.BackgroundColor3 = theme.accordionBg
    hdr.BorderSizePixel = 0
    hdr.Text = "  " .. title .. (open[1] and "  ▲" or "  ▼")
    hdr.Font = Enum.Font.GothamBold
    hdr.TextSize = 10
    hdr.TextColor3 = theme.accordionTxt
    hdr.TextXAlignment = Enum.TextXAlignment.Left
    hdr.ZIndex = 2
    hdr.Parent = parent
    mkCorner(hdr, 7)

    -- ── Body (ukuran sementara 0 dulu) ───────────────────────
    local body = Instance.new("Frame")
    body.Size = UDim2.new(1, 0, 0, 0)
    body.Position = UDim2.new(0, 0, 0, yOff + 30)
    body.BackgroundTransparency = 1
    body.BorderSizePixel = 0
    body.ClipsDescendants = true
    body.Visible = open[1]
    body.Parent = parent

    -- ── Jalankan builderFn → ukur tinggi otomatis ────────────
    local inner = Section.new(body, self._mf, theme, accordionStates)
    if builderFn then builderFn(inner) end
    local innerH = inner._y + 8   -- padding bawah 8px

    -- Set ukuran body sebenarnya setelah isi dibangun
    body.Size = UDim2.new(1, 0, 0, innerH)

    -- ── Toggle logic ─────────────────────────────────────────
    hdr.MouseButton1Click:Connect(function()
        open[1] = not open[1]
        if stateKey then accordionStates[stateKey] = open[1] end
        body.Visible = open[1]
        hdr.Text = "  " .. title .. (open[1] and "  ▲" or "  ▼")
        local shift = open[1] and innerH or -innerH
        local threshold = hdr.Position.Y.Offset + 26
        for _, child in ipairs(parent:GetChildren()) do
            if child ~= hdr and child ~= body then
                if child.Position.Y.Offset > threshold then
                    child.Position = UDim2.new(
                        child.Position.X.Scale, child.Position.X.Offset,
                        0, child.Position.Y.Offset + shift
                    )
                end
            end
        end
        parent.CanvasSize = UDim2.new(0, 0, 0, parent.CanvasSize.Y.Offset + shift)
    end)

    local addedH = 30 + (open[1] and innerH or 0)
    self._y = yOff + addedH + (opts.gap or 4)
    return inner
end

-- Escape hatch: build custom UI langsung ke container
function Section:Custom(fn)
    fn(self._c, self._y, self._t)
end

function Section:_updateCanvas()
    self._c.CanvasSize = UDim2.new(0, 0, 0, self._y + 10)
end

